# Local ArmOS build and launch configuration.
# Copy this file to armos.conf; the local file is intentionally not tracked.

TARGET_ARCH=arm32
TARGET_PLATFORM=qemu-virt
SMP_CPUS=1

# QEMU launch features. Both may be enabled together.
ENABLE_NET=no
ENABLE_GPU=no

# Raspberry Pi 3 displays and USB. Select either ILI9341 or HDMI. HDMI uses
# the firmware framebuffer; USB enables the DWC2 host and boot HID devices.
# ENABLE_ILI9341=no
# ENABLE_HDMI=no
# HDMI_WIDTH=1280
# HDMI_HEIGHT=720
# ENABLE_USB=no

# Userland build content.
BUILD_NEWLIB=yes
BUILD_ALL_USERLAND=no
BUILD_TCC=yes
BUILD_BSD=no
BUILD_NCURSES=no
BUILD_NANO=no
BUILD_XV_DEPS=no
BUILD_FBVIEW=no

# Optional QEMU and network overrides.
# QEMU_MEMORY=2G
# NET_HOST_PORT=2323
# GPU_XRES=1024
# GPU_YRES=768
