# ArmOS conservative terminal entry.
#
# Keep this entry aligned with kernel/drivers/display.c. In particular, do not
# advertise scroll regions, insert/delete line, alternate screen, or advanced
# erase semantics before the console backend really implements them.
armos|ArmOS framebuffer/UART ANSI console,
        am,
        colors#8, cols#80, it#8, lines#24, pairs#64,
        bel=^G,
        bold=\E[1m,
        clear=\E[H\E[2J,
        cr=\r,
        cub1=\E[D,
        cud1=\E[B,
        cuf1=\E[C,
        cup=\E[%i%p1%d;%p2%dH,
        cuu1=\E[A,
        cvvis=\E[?25h,
        civis=\E[?25l,
        cnorm=\E[?25h,
        ed=\E[J,
        el=\E[K,
        home=\E[H,
        kbs=\177,
        kcub1=\E[D,
        kcud1=\E[B,
        kcuf1=\E[C,
        kcuu1=\E[A,
        khome=\E[H,
        kend=\E[F,
        kdch1=\E[3~,
        knp=\E[6~,
        kpp=\E[5~,
        op=\E[39;49m,
        rev=\E[7m,
        rmam=\E[?7l,
        sgr0=\E[0m,
        setaf=\E[3%p1%dm,
        setab=\E[4%p1%dm,
        smam=\E[?7h,
