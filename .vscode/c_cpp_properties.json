                "${workspaceFolder}/userland/include",
                "${workspaceFolder}/userland/system/mash/include",
                "${workspaceFolder}/userland/opt/tcc/include",
                "${workspaceFolder}/userland/opt/tcc/src/include"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}/arch/arm32/include",
                    "${workspaceFolder}/include",
                    "${workspaceFolder}/build/generated",
                    "${workspaceFolder}/build/include",
                    "${workspaceFolder}/build/newlib-sysroot/arm-none-eabi/include",
                    "${workspaceFolder}/userland/include",
                    "${workspaceFolder}/userland/system/mash/include",
