{
    "configurations": [
        {
            "name": "ARM",
            "compilerPath": "arm-none-eabi-gcc",
            "defines": [
                "ARMV7A_KERNEL",
                "_FORTIFY_SOURCE=0",
                "__NO_BUILTIN"
            ],
            "includePath": [
                "./arch/arm32/include",
                "./include",
                "./build/generated",
                "./build/include",
                "./libc/include",
                "./build/newlib-sysroot/arm-none-eabi/include",
                "./userland/include",
                "./userland/system/mash/include",
                "./userland/opt/tcc/include",
                "./userland/opt/tcc/src/include",
                "./userland/legacy/myshell/include"
            ],
            "browse": {
                "path": [
                    "./arch/arm32/include",
                    "./include",
                    "./build/generated",
                    "./build/include",
                    "./libc/include",
                    "./build/newlib-sysroot/arm-none-eabi/include",
                    "./userland/include",
                    "./userland/system/mash/include",
                    "./userland/opt/tcc/include",
                    "./userland/opt/tcc/src/include",
                    "./userland/legacy/myshell/include"
                ],
                "limitSymbolsToIncludedHeaders": true
            },
            "compilerArgs": [
                "-mcpu=cortex-a15",
                "-marm",
                "-mfpu=neon-vfpv4",
                "-mfloat-abi=soft",
                "-fno-builtin",
                "-nostdlib",
                "-nostdinc"
            ],
            "macFrameworkPath": [
                "/System/Library/Frameworks",
                "/Library/Frameworks"
            ],
            "intelliSenseMode": "gcc-arm",
            "cStandard": "gnu99",
            "cppStandard": "c++14"
        }
    ],
    "version": 4
}
