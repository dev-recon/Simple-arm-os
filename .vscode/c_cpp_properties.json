{
    "configurations": [
        {
            "name": "ARM",
            "compilerPath": "/opt/homebrew/bin/arm-none-eabi-gcc",
            "defines": [
                "_FORTIFY_SOURCE=0",
                "__NO_BUILTIN"
            ],
            "includePath": [
                "./include/",
                "./libc/include",
                "./build/include",
                "./userland/myshell/include"
            ],
            "compilerArgs": [
                "-fno-builtin",
                "-nostdlib",
                "-nostdinc"
            ],
            "macFrameworkPath": [
                "/System/Library/Frameworks",
                "/Library/Frameworks"
            ],
            "intelliSenseMode": "macos-clang-x64",
            "cStandard": "gnu99",
            "cppStandard": "c++14"
        }
    ],
    "version": 4
}