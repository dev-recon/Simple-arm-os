{
    "tasks": [
        {
            "label": "ArmOS: build qemu-virt kernel",
            "type": "shell",
            "command": "make",
            "args": [
                "platform-kernel",
                "TARGET_ARCH=arm32",
                "TARGET_PLATFORM=qemu-virt"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "ArmOS: build raspi2 kernel",
            "type": "shell",
            "command": "make",
            "args": [
                "platform-kernel",
                "TARGET_ARCH=arm32",
                "TARGET_PLATFORM=raspi2"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: arm-none-eabi-gcc générer le fichier actif",
            "command": "arm-none-eabi-gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-std=gnu99",
                "-mcpu=cortex-a15",
                "-marm",
                "-mfpu=neon-vfpv4",
                "-mfloat-abi=soft",
                "-ffreestanding",
                "-nostdlib",
                "-nostartfiles",
                "-fno-builtin",
                "-DARMV7A_KERNEL",
                "-I${workspaceFolder}/arch/arm32/include",
                "-I${workspaceFolder}/include",
                "-I${workspaceFolder}/build/generated",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Tâche générée par le débogueur."
        }
    ],
    "version": "2.0.0"
}
